-- --- MECÂNICAS OPERACIONAIS ---

local function atualizarCamposDeEdicao()
    local nota = tabelaNotas[indiceNotaAtiva]
    if nota then
        InputTitulo.Text = nota.titulo
        InputConteudo.Text = nota.conteudo
        InputTitulo.Interactable = true
        InputConteudo.Interactable = true
    else
        InputTitulo.Text = ""
        -- Texto padrão idêntico ao solicitado da imagem 2 para telas zeradas
        InputConteudo.Text = "Crie uma nova seção clicando no botão '+'."
        InputTitulo.Interactable = false
        InputConteudo.Interactable = false
    end
end

local function renderizarListaLateral()
    for _, child in ipairs(ListaSecoesContainer:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for index, nota in ipairs(tabelaNotas) do
        local botaoNota = Create("TextButton", ListaSecoesContainer, {
            Name = "Nota_" .. index,
            Size = UDim2.new(1, -5, 0, 36), 
            BackgroundColor3 = (index == indiceNotaAtiva) and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(28, 28, 28),
            Text = nota.titulo,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            Font = FONTE_PADRAO,
            TextSize = 12,
            TextWrapped = true
        })
        Create("UICorner", botaoNota, {CornerRadius = UDim.new(0, 6)})
        
        botaoNota.MouseButton1Click:Connect(function()
            if tabelaNotas[indiceNotaAtiva] then
                tabelaNotas[indiceNotaAtiva].titulo = InputTitulo.Text
                tabelaNotas[indiceNotaAtiva].conteudo = InputConteudo.Text
            end
            indiceNotaAtiva = index
            renderizarListaLateral()
            atualizarCamposDeEdicao()
        end)
    end
    ListaSecoesContainer.CanvasSize = UDim2.new(0, 0, 0, LayoutLista.AbsoluteContentSize.Y)
end

InputTitulo:GetPropertyChangedSignal("Text"):Connect(function()
    if tabelaNotas[indiceNotaAtiva] then
        tabelaNotas[indiceNotaAtiva].titulo = InputTitulo.Text
        local btn = ListaSecoesContainer:FindFirstChild("Nota_" .. indiceNotaAtiva)
        if btn then btn.Text = InputTitulo.Text end
    end
end)

InputConteudo:GetPropertyChangedSignal("Text"):Connect(function()
    if tabelaNotas[indiceNotaAtiva] then
        tabelaNotas[indiceNotaAtiva].conteudo = InputConteudo.Text
    end
end)

BotaoAdicionar.MouseButton1Click:Connect(function()
    table.insert(tabelaNotas, {titulo = "NOVA NOTA", conteudo = ""})
    indiceNotaAtiva = #tabelaNotas
    renderizarListaLateral()
    atualizarCamposDeEdicao()
end)

BotaoExcluir.MouseButton1Click:Connect(function()
    if #tabelaNotas > 0 and indiceNotaAtiva > 0 then
        table.remove(tabelaNotas, indiceNotaAtiva)
        if indiceNotaAtiva > #tabelaNotas then indiceNotaAtiva = #tabelaNotas end
        if indiceNotaAtiva == 0 and #tabelaNotas > 0 then indiceNotaAtiva = 1 end
        renderizarListaLateral()
        atualizarCamposDeEdicao()
    end
end)

local aberto = false
local function alternarPainel()
    aberto = not aberto
    if aberto then
        MainFrame.Visible = true
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 450, 0, 340)}):Play()
    else
        local tween = TweenService:Create(MainFrame, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 0)})
        tween:Play()
        tween.Completed:Connect(function() if not aberto then MainFrame.Visible = false end end)
    end
end

local function destruirInterface()
    ScreenGui:Destroy()
end

OpenBtn.MouseButton1Click:Connect(alternarPainel)
BotaoSalvar.MouseButton1Click:Connect(salvarDadosLocais)

BotaoXSuperior.MouseButton1Click:Connect(destruirInterface)
BotaoCloseCentral.MouseButton1Click:Connect(destruirInterface)

renderizarListaLateral()
atualizarCamposDeEdicao()
