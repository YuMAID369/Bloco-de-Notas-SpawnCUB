-- --- ENGINE DE PERSISTÊNCIA DE DADOS ---
local tabelaNotas = {}
local indiceNotaAtiva = 0 -- Inicia em 0 para indicar nenhuma nota criada/ativa de primeira

local function carregarDadosLocais()
    local sucesso, conteudo = pcall(function()
        if readfile then return readfile(SAVE_FILE_NAME) end
    end)
    if sucesso and conteudo then
        pcall(function() tabelaNotas = HttpService:JSONDecode(conteudo) end)
    end
    -- Resetado para que a primeira execução venha totalmente vazia igual à imagem 2
    if not tabelaNotas or #tabelaNotas == 0 then
        tabelaNotas = {}
        indiceNotaAtiva = 0
    else
        indiceNotaAtiva = 1
    end
end

local function salvarDadosLocais()
    if writefile and #tabelaNotas > 0 then
        pcall(function()
            local json = HttpService:JSONEncode(tabelaNotas)
            writefile(SAVE_FILE_NAME, json)
        end)
    end
end

